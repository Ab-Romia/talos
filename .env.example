# API Keys
OPENAI_API_KEY=sk-...

# Models
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=documents_v2

# Retrieval
RETRIEVAL_TOP_K=5
RERANK_TOP_K=3
USE_HYBRID_RETRIEVAL=true
USE_RERANKING=true

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKING_STRATEGY=recursive

# Memory
CONVERSATION_MEMORY_K=3
