# =============================================================================
# Talos RAG System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true
DB_ECHO=false

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://talos_app:your_secure_password@localhost:5432/talos
POSTGRES_USER=talos_app
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=talos

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ARGON2_SECRET=your-argon2-secret-change-in-production

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# RAG System Configuration
# -----------------------------------------------------------------------------
# OpenAI API Key (required for embeddings and LLM)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Milvus Vector Database
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=talos_documents

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE=52428800

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_STREAMING=true
ENABLE_DOCUMENT_UPLOAD=true
